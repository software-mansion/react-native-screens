{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@apps/*": ["src/*"],
      "@assets/*": ["assets/*"],
      "react-native-screens": ["../src"],
      "react-native-screens/*": ["../src/*"],
      "@react-navigation/*": ["../react-navigation/packages/*/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js"]
}
