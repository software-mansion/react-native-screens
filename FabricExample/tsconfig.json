{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["jest", "node"],
    "paths": {
      "@apps/*": ["../apps/src/*"],
      "@assets/*": ["../apps/assets/*"],
      "react-native-screens": ["../src"],
      "react-native-screens/*": ["../src/*"]
    }
  }
}
