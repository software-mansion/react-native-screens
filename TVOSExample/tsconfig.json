{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@apps/*": ["../apps/src/*"],
      "@assets/*": ["../apps/assets/*"],
      "react-native-screens": ["../src"],
      "react-native-screens/*": ["../src/*"]
    },
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
